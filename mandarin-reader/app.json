{
  "expo": {
    "name": "读中文 Mandarin Reader",
    "slug": "mandarin-reader",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mandarinreader",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "android": {
      "package": "com.pepermints.mandarinreader",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F6F1E7"
      }
    },
    "ios": {
      "bundleIdentifier": "com.pepermints.mandarinreader",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F6F1E7"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7d1c54a1-a89f-4d25-ae11-10cbdd6c3637"
      }
    }
  }
}
